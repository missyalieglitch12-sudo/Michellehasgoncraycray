// --- INITIALIZATION ---
window.addEventListener('DOMContentLoaded', async () => {
  // 1. Setup clocks
  startLiveClock();

  // 2. Load settings
  loadUserSettings();

  // 3. Connect to Database
  try {
    await DB.init();
    await seedMockDataIfEmpty();
    await reloadDatabaseState();
  } catch (err) {
    console.error("DB Initialization failed", err);
    showNotification("ERROR: Database connection failed!", "error");
  }

  // 4. Populate calendar select lists
  setupCalendarSelectors();

  // 5. Setup UI interactions
  setupEventListeners();

  // 6. Select today by default and render calendar
  STATE.selectedDate = getTodayDateString();
  renderCalendar();
  updateSelectedDateInfoDisplay();

  // 7. Load note from today or create blank
  loadNoteForSelectedDate();

  // 8. Load archive entries list
  renderArchive();

  // 9. Restore window layout preferences from localStorage
  loadWindowLayoutSettings();

  // 10. Init Sticker Engine
  if (window.StickerEngine) {
    StickerEngine.init('editor-paper');
  }
});

// Live clock loop
function startLiveClock() {
  function tick() {
    const now = new Date();
    DOM.liveTime.textContent = now.toLocaleTimeString();
    
    const options = { weekday: 'short', year: 'numeric', month: 'short', day: '2-digit' };
    DOM.liveDate.textContent = now.toLocaleDateString('en-US', options).toUpperCase();
  }
  tick();
  setInterval(tick, 1000);
}

// User settings from localStorage (simple settings)
function loadUserSettings() {
  const sound = localStorage.getItem('setting_sound');
  if (sound !== null) {
    STATE.soundEnabled = sound === 'true';
    updateSoundButtonUI();
  }

  const contrast = localStorage.getItem('setting_contrast');
  if (contrast === 'true') {
    STATE.highContrastMode = true;
    document.body.classList.add('dark-mode');
    DOM.darkThemeToggle.classList.add('active');
    DOM.darkThemeToggle.textContent = "🌓 NORMAL CONTRAST";
  }
}

function updateSoundButtonUI() {
  if (STATE.soundEnabled) {
    DOM.synthSoundToggle.classList.add('active');
    DOM.synthSoundToggle.textContent = "🔊 SOUNDS: ON";
  } else {
    DOM.synthSoundToggle.classList.remove('active');
    DOM.synthSoundToggle.textContent = "🔇 SOUNDS: OFF";
  }
}

async function reloadDatabaseState() {
  STATE.entries = await DB.getAll();
}

