      currentCalendarYear--;
    }
    DOM.calendarMonthSelect.value = currentCalendarMonth;
    DOM.calendarYearSelect.value = currentCalendarYear;
    renderCalendar();
    Synth.play('click');
  });

  DOM.nextMonthBtn.addEventListener('click', () => {
    currentCalendarMonth++;
    if (currentCalendarMonth > 11) {
      currentCalendarMonth = 0;
      currentCalendarYear++;
    }
    DOM.calendarMonthSelect.value = currentCalendarMonth;
    DOM.calendarYearSelect.value = currentCalendarYear;
    renderCalendar();
    Synth.play('click');
  });

  DOM.addNoteForDayBtn.addEventListener('click', () => {
    // Check if day already has notes
    const existing = STATE.entries.find(e => e.dateString === STATE.selectedDate);
    if (existing) {
      loadNoteIntoWorkspace(existing);
      showNotification("loaded existing day note!");
    } else {
      const blank = createBlankNote(STATE.selectedDate);
      loadNoteIntoWorkspace(blank);
      showNotification("created note for " + STATE.selectedDate);
      DOM.noteTitle.focus();
