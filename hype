  });

  // Archive panel interactions
  DOM.archiveSearch.addEventListener('input', () => {
    renderArchive();
  });

  DOM.archiveFilterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      DOM.archiveFilterBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      Synth.play('click');
      renderArchive();
    });
  });

  DOM.archiveDateFilter.addEventListener('change', () => {
    Synth.play('click');
    renderArchive();
  });

  DOM.archiveSort.addEventListener('change', () => {
    Synth.play('click');
    renderArchive();
  });

  DOM.createNewBlankBtn.addEventListener('click', () => {
    Synth.play('success');
    const blank = createBlankNote(null); // Dateless by default
    loadNoteIntoWorkspace(blank);
    showNotification("NEW INBOX ENTRY CREATED");
    DOM.noteTitle.focus();
  });

  // Desktop OS Taskbar toggles
  DOM.toggleCalendarBtn.addEventListener('click', () => {
    toggleDesktopWindow('calendar');
  });
  DOM.toggleEditorBtn.addEventListener('click', () => {
    toggleDesktopWindow('editor');
  });
  DOM.toggleArchiveBtn.addEventListener('click', () => {
    toggleDesktopWindow('archive');
  });

  // Windows close buttons
  DOM.windowCloseBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const target = btn.dataset.target;
      toggleDesktopWindow(target, false);
    });
  });

  // Audio discard mistakes button
  DOM.discardAudioBtn.addEventListener('click', () => {
    if (!confirm("Discard/delete this audio memo recording?")) return;
    Synth.play('delete');
    stopAudioPlayback();
    STATE.activeNote.content = null;
    setupAudioWorkspaceView();
    triggerAutoSave();
    showNotification("AUDIO RECORDING DELETED!");
  });

  // Background Studio Modal
  const bgModal = document.getElementById('bg-studio-modal');
  document.getElementById('bg-studio-btn').addEventListener('click', () => {
    bgModal.classList.remove('hidden');
    loadPhotoGallery();
  });
  document.getElementById('close-bg-modal').addEventListener('click', () => {
    bgModal.classList.add('hidden');
  });

  // Tab switching
  document.querySelectorAll('.bg-tab-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.bg-tab-btn').forEach(b => b.classList.remove('active'));
      document.querySelectorAll('.bg-tab-content').forEach(c => c.classList.add('hidden'));
      btn.classList.add('active');
      document.getElementById('bg-tab-' + btn.dataset.tab).classList.remove('hidden');
    });
  });

  // Custom Color Picker
  const customColorPicker = document.getElementById('custom-color-picker');
  customColorPicker.addEventListener('change', (e) => {
    STATE.activeNote.paperColor = e.target.value;
    STATE.activeNote.background = null;
    DOM.colorBtns.forEach(b => b.classList.remove('active'));
    updatePaperStyling();
    triggerAutoSave();
  });

  // Pattern selection
  document.querySelectorAll('.pattern-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      STATE.activeNote.background = { type: 'pattern', value: btn.dataset.pattern };
      updatePaperStyling();
      triggerAutoSave();
      bgModal.classList.add('hidden');
    });
  });

  // Clone Swatches for Modal
  const modalColorPicker = document.getElementById('modal-color-picker');
  if (modalColorPicker) {
    document.querySelectorAll('.color-btn').forEach(btn => {
      const clone = btn.cloneNode(true);
      clone.addEventListener('click', () => {
        STATE.activeNote.paperColor = clone.dataset.color;
        STATE.activeNote.background = null;
        updatePaperStyling();
        triggerAutoSave();
        bgModal.classList.add('hidden');
      });
      modalColorPicker.appendChild(clone);
    });
  }

  // Image Upload
  document.getElementById('upload-bg-image-btn').addEventListener('click', () => {
    document.getElementById('bg-image-upload').click();
  });

  document.getElementById('bg-image-upload').addEventListener('change', async (e) => {
    const file = e.target.files[0];
    if (file) {
      const base64 = await compressImage(file);
      const photoObj = { id: generateId(), data: base64 };
      await DB.savePhoto(photoObj);
      loadPhotoGallery();
    }
  });

  // Sticker Studio Modal
  const stickerModal = document.getElementById('sticker-modal');
  if (stickerModal) {
