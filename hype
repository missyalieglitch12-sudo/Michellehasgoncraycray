  });

  // Editor views tabs
  DOM.editorTabs.forEach(tab => {
    tab.addEventListener('click', () => {
      if (tab.dataset.type === STATE.activeNote.type) return;
      
      // Confirm clear content if swapping note types with actual data
      let proceed = true;
      if (STATE.activeNote.type === 'text' && DOM.noteTextarea.value.trim() !== '') {
        proceed = confirm("Change note type? Your notepad text will be cleared.");
      } else if (STATE.activeNote.type === 'list' && Array.isArray(STATE.activeNote.content) && STATE.activeNote.content.length > 0) {
        proceed = confirm("Change note type? Your checklist items will be cleared.");
      } else if (STATE.activeNote.type === 'audio' && STATE.activeNote.content instanceof Blob) {
        proceed = confirm("Change note type? Your audio recording will be deleted.");
      }

      if (proceed) {
        // Reset contents
        if (tab.dataset.type === 'text') STATE.activeNote.content = '';
        else if (tab.dataset.type === 'list') STATE.activeNote.content = [];
        else if (tab.dataset.type === 'audio') STATE.activeNote.content = null;

        DOM.noteTextarea.value = '';
        DOM.checklistNewItem.value = '';
        
