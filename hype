  }

  // Populate view contents based on type
  if (STATE.activeNote.type === 'text') {
    DOM.noteTextarea.value = STATE.activeNote.content || '';
  } 
  else if (STATE.activeNote.type === 'list') {
    renderWorkspaceChecklist();
