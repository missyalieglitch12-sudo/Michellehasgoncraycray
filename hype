// --- NOTIFICATION UTILITY ---
let notificationTimeout = null;
function showNotification(message, type = 'success') {
  DOM.notificationText.textContent = message.toUpperCase();
  
  if (type === 'error') {
    DOM.notificationPopover.style.borderColor = 'var(--accent-pink)';
    DOM.notificationPopover.style.boxShadow = '4px 4px 0px var(--accent-pink)';
    DOM.notificationPopover.style.color = 'var(--accent-pink)';
  } else {
    DOM.notificationPopover.style.borderColor = 'var(--accent-lime)';
    DOM.notificationPopover.style.boxShadow = '4px 4px 0px var(--accent-lime)';
    DOM.notificationPopover.style.color = 'var(--accent-lime)';
  }
  
  DOM.notificationPopover.classList.remove('hidden');

  clearTimeout(notificationTimeout);
  notificationTimeout = setTimeout(() => {
    DOM.notificationPopover.classList.add('hidden');
  }, 2500);
}

// --- CALENDAR SYSTEM CORE ---
let currentCalendarYear = new Date().getFullYear();
let currentCalendarMonth = new Date().getMonth(); // 0-indexed

function setupCalendarSelectors() {
  // Populate Months
  const months = ["January", "February", "March", "April", "May", "June", "July", "August", "September", "October", "November", "December"];
  DOM.calendarMonthSelect.innerHTML = '';
  months.forEach((m, idx) => {
    const opt = document.createElement('option');
    opt.value = idx;
    opt.textContent = m.toUpperCase();
    DOM.calendarMonthSelect.appendChild(opt);
  });

  // Populate Years (e.g. from 2020 to 2035)
  DOM.calendarYearSelect.innerHTML = '';
  for (let y = 2020; y <= 2035; y++) {
    const opt = document.createElement('option');
    opt.value = y;
    opt.textContent = y;
    DOM.calendarYearSelect.appendChild(opt);
  }

  // Set initial selections
  DOM.calendarMonthSelect.value = currentCalendarMonth;
  DOM.calendarYearSelect.value = currentCalendarYear;
}

function renderCalendar() {
  DOM.calendarGrid.innerHTML = '';
  
  const firstDayIndex = new Date(currentCalendarYear, currentCalendarMonth, 1).getDay(); // Sun=0, Mon=1...
  // Shift Sunday to be index 6 (so Mon=0, Tue=1, ..., Sun=6)
  let firstDayAdjusted = firstDayIndex - 1;
  if (firstDayAdjusted === -1) firstDayAdjusted = 6; 

  const daysInMonth = new Date(currentCalendarYear, currentCalendarMonth + 1, 0).getDate();
  const daysInPrevMonth = new Date(currentCalendarYear, currentCalendarMonth, 0).getDate();
  
  const totalCells = 42; // standard 6 rows of 7
  
  // Array of elements to append
  const cells = [];

  // 1. Previous Month Days
  for (let i = firstDayAdjusted - 1; i >= 0; i--) {
    const dayNum = daysInPrevMonth - i;
    const prevMonthIdx = currentCalendarMonth === 0 ? 11 : currentCalendarMonth - 1;
    const prevYearVal = currentCalendarMonth === 0 ? currentCalendarYear - 1 : currentCalendarYear;
    
    cells.push({
      day: dayNum,
      month: prevMonthIdx,
      year: prevYearVal,
      isCurrentMonth: false
    });
  }

  // 2. Current Month Days
  for (let i = 1; i <= daysInMonth; i++) {
    cells.push({
      day: i,
      month: currentCalendarMonth,
      year: currentCalendarYear,
      isCurrentMonth: true
    });
  }

  // 3. Next Month Days
  const nextDaysNeeded = totalCells - cells.length;
  for (let i = 1; i <= nextDaysNeeded; i++) {
    const nextMonthIdx = currentCalendarMonth === 11 ? 0 : currentCalendarMonth + 1;
    const nextYearVal = currentCalendarMonth === 11 ? currentCalendarYear + 1 : currentCalendarYear;
    
    cells.push({
      day: i,
      month: nextMonthIdx,
      year: nextYearVal,
      isCurrentMonth: false
    });
  }

  // Render cells to DOM
  const todayStr = getTodayDateString();
  
  cells.forEach(c => {
    const cellEl = document.createElement('div');
    cellEl.classList.add('calendar-day');
    if (!c.isCurrentMonth) {
      cellEl.classList.add('other-month');
    }
    
    const dateStr = `${c.year}-${String(c.month + 1).padStart(2, '0')}-${String(c.day).padStart(2, '0')}`;
    cellEl.dataset.date = dateStr;
    
    // Day number
    const numEl = document.createElement('span');
    numEl.textContent = c.day;
    cellEl.appendChild(numEl);

    // Indicator dots row
    const dotsEl = document.createElement('div');
    dotsEl.classList.add('calendar-dots');
    cellEl.appendChild(dotsEl);

    // Add visual dots for entries on this day
    const entriesOnDay = STATE.entries.filter(e => e.dateString === dateStr);
    if (entriesOnDay.length > 0) {
      const hasText = entriesOnDay.some(e => e.type === 'text');
      const hasList = entriesOnDay.some(e => e.type === 'list');
      const hasAudio = entriesOnDay.some(e => e.type === 'audio');

      if (hasText) {
        const dot = document.createElement('span');
        dot.classList.add('calendar-dot', 'dot-text');
        dotsEl.appendChild(dot);
      }
      if (hasList) {
        const dot = document.createElement('span');
        dot.classList.add('calendar-dot', 'dot-list');
        dotsEl.appendChild(dot);
      }
      if (hasAudio) {
        const dot = document.createElement('span');
        dot.classList.add('calendar-dot', 'dot-audio');
        dotsEl.appendChild(dot);
      }
    }

    // Highlighting today
    if (dateStr === todayStr) {
      cellEl.classList.add('today');
    }

    // Highlighting selected
    if (dateStr === STATE.selectedDate) {
      cellEl.classList.add('selected');
    }

    // Click handler
    cellEl.addEventListener('click', () => {
      Synth.play('click');
      document.querySelectorAll('.calendar-day').forEach(el => el.classList.remove('selected'));
      cellEl.classList.add('selected');
      
      STATE.selectedDate = dateStr;
      updateSelectedDateInfoDisplay();
      loadNoteForSelectedDate();
    });

    DOM.calendarGrid.appendChild(cellEl);
  });
}

function updateSelectedDateInfoDisplay() {
  DOM.selectedDateDisplay.textContent = formatDateDisplay(STATE.selectedDate);
}

// Load notes for selected calendar cell
function loadNoteForSelectedDate() {
  const match = STATE.entries.find(e => e.dateString === STATE.selectedDate);
  if (match) {
    loadNoteIntoWorkspace(match);
  } else {
    // Offer blank note tied to this date, but don't save yet to avoid DB bloat
    const blank = createBlankNote(STATE.selectedDate);
    loadNoteIntoWorkspace(blank);
  }
}

// --- WORKSPACE EDITOR CONTROLLER ---

function loadNoteIntoWorkspace(note) {
  // Clear any running audio playback
  stopAudioPlayback();

  STATE.activeNote = JSON.parse(JSON.stringify(note)); // Deep copy to avoid early mutations
  
  // If it's a voice note, copy the actual blob reference back because JSON.stringify strips it!
  if (note.type === 'audio' && note.content instanceof Blob) {
    STATE.activeNote.content = note.content;
  }

  // Populate title
  DOM.noteTitle.value = STATE.activeNote.title || '';
  
  // Restore Stickers
  if (window.StickerEngine) {
    StickerEngine.restore(STATE.activeNote.stickers || []);
  }

  // Set tab view
  setActiveEditorTab(STATE.activeNote.type);
  
  // Select values in dropdowns
  DOM.paperStyleSelect.value = STATE.activeNote.paperType;
  DOM.fontSelect.value = STATE.activeNote.fontFamily;
  
  // Load paper classes
  updatePaperStyling();

  // Load color picker state
  DOM.colorBtns.forEach(btn => {
    if (btn.dataset.color === STATE.activeNote.paperColor) {
      btn.classList.add('active');
    } else {
      btn.classList.remove('active');
    }
  });

  // Calendar Link checkbox
  if (STATE.activeNote.dateString) {
    DOM.linkToDateChk.checked = true;
    DOM.dateLinkPickers.classList.remove('hidden');
    DOM.noteDatePicker.value = STATE.activeNote.dateString;
    DOM.noteTimePicker.value = STATE.activeNote.timeString || '';
  } else {
    DOM.linkToDateChk.checked = false;
    DOM.dateLinkPickers.classList.add('hidden');
    DOM.noteDatePicker.value = getTodayDateString();
    DOM.noteTimePicker.value = '';
  }

  // Set Save badge status
  const exists = STATE.entries.some(e => e.id === STATE.activeNote.id);
  DOM.saveStatus.textContent = exists ? "SAVED" : "DRAFT";
  DOM.saveStatus.className = "save-status-badge";
