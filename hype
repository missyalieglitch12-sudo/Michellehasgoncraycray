// --- CHECKLIST WRITER ---
function renderWorkspaceChecklist() {
  DOM.checklistItemsContainer.innerHTML = '';
  
  // Ensure content is array
  if (!Array.isArray(STATE.activeNote.content)) {
    STATE.activeNote.content = [];
  }

  if (STATE.activeNote.content.length === 0) {
    DOM.checklistItemsContainer.innerHTML = '<div class="empty-state">No tasks. Type below to add one!</div>';
    return;
  }

  STATE.activeNote.content.forEach((item, index) => {
    const row = document.createElement('div');
    row.classList.add('checklist-item');
    if (item.checked) row.classList.add('checked');

    // Left container (checkbox + text)
    const left = document.createElement('div');
    left.classList.add('checklist-item-content');

    const chkLabel = document.createElement('label');
    chkLabel.classList.add('neo-checkbox-container');
    
    const input = document.createElement('input');
    input.type = 'checkbox';
    input.checked = item.checked;
    
    const span = document.createElement('span');
    span.classList.add('custom-checkbox');

    chkLabel.appendChild(input);
    chkLabel.appendChild(span);
    left.appendChild(chkLabel);

    const txt = document.createElement('span');
    txt.classList.add('checklist-item-text');
    txt.textContent = item.text;
    left.appendChild(txt);

    row.appendChild(left);

    // Right container (delete button)
    const delBtn = document.createElement('button');
    delBtn.classList.add('delete-item-btn');
    delBtn.innerHTML = '×';
    delBtn.title = 'Delete item';
    row.appendChild(delBtn);

    // Event listeners
    input.addEventListener('change', () => {
      item.checked = input.checked;
      if (item.checked) {
        Synth.play('success');
        setMascot('\\(•◡•)/', 'task complete!', 'active');
      } else {
        Synth.play('click');
        setMascot('(•‿•)', 'updated list', 'active');
      }
      row.classList.toggle('checked', item.checked);
      triggerAutoSave();
    });

    delBtn.addEventListener('click', () => {
      Synth.play('delete');
      STATE.activeNote.content.splice(index, 1);
      renderWorkspaceChecklist();
      triggerAutoSave();
    });

    DOM.checklistItemsContainer.appendChild(row);
  });
}

function addNewChecklistItem() {
  const txt = DOM.checklistNewItem.value.trim();
  if (!txt) return;

  if (!Array.isArray(STATE.activeNote.content)) {
    STATE.activeNote.content = [];
  }

  STATE.activeNote.content.push({ text: txt, checked: false });
  DOM.checklistNewItem.value = '';
  
  Synth.play('click');
  renderWorkspaceChecklist();
  triggerAutoSave();
  DOM.checklistNewItem.focus();
}

// --- AUDIO RECORDER MODULE ---

function setupAudioWorkspaceView() {
  // Clear any existing recordings/visualizers
  stopAudioPlayback();
  
  // Disable stop button, reset cassette styling
  DOM.stopBtn.classList.add('disabled');
  DOM.stopBtn.disabled = true;
  DOM.recBtn.classList.remove('disabled', 'recording');
  DOM.recBtn.disabled = false;
  DOM.recBtn.innerHTML = '<span class="rec-icon"></span> REC';
  
  DOM.leftSpool.classList.remove('spinning');
  DOM.rightSpool.classList.remove('spinning');
  
  // Set initial tape roll width
  DOM.tapeRoll.style.width = '35px';

  // If a recording exists, load it
  if (STATE.activeNote.content instanceof Blob) {
    DOM.recordingState.textContent = "SAVED AUDIO MEMO READY";
    DOM.recordingTimer.textContent = formatTimerSeconds(Math.round(STATE.activeNote.content.size / 32000)); // Estimated duration approximation
    
    // Fetch actual duration from player metadata once loaded
    setupCustomPlayer(STATE.activeNote.content);
    DOM.cassetteLabelTitle.textContent = STATE.activeNote.title || 'VOICE RECORDING';
  } else {
    DOM.recordingState.textContent = "READY TO RECORD";
    DOM.recordingTimer.textContent = "00:00";
    DOM.audioPlayerContainer.classList.add('hidden');
    DOM.cassetteLabelTitle.textContent = "BLANK CASSETTE";
  }

  // Draw static lines on visualizer canvas
  drawStaticVisualizer();
}

function drawStaticVisualizer() {
  const canvas = DOM.audioVisualizer;
  const ctx = canvas.getContext('2d');
  
  // Fix resolution sizing
  canvas.width = canvas.parentElement.clientWidth;
  canvas.height = canvas.parentElement.clientHeight;

  ctx.fillStyle = '#ffffff';
  ctx.fillRect(0, 0, canvas.width, canvas.height);
  
  ctx.strokeStyle = '#000000';
  ctx.lineWidth = 2;
  ctx.beginPath();
  ctx.moveTo(0, canvas.height / 2);
  ctx.lineTo(canvas.width, canvas.height / 2);
  ctx.stroke();
}

// Record Action
async function startAudioRecording() {
  if (STATE.isRecording) return;
  stopAudioPlayback();

  try {
    STATE.audioStream = await navigator.mediaDevices.getUserMedia({ audio: true });
    
    // Set recording flag
    STATE.isRecording = true;
    STATE.audioChunks = [];
    STATE.recordDuration = 0;
    
    Synth.play('record-start');
    setMascot('(☉_☉)', 'recording audio...', 'recording');

    // UI Updates
    DOM.recBtn.classList.add('recording');
    DOM.recBtn.innerHTML = '● REC';
    DOM.stopBtn.classList.remove('disabled');
    DOM.stopBtn.disabled = false;
    DOM.recordingState.textContent = "RECORDING NOW...";
    DOM.cassetteLabelTitle.textContent = "RECORDING IN PROGRESS";
    DOM.audioPlayerContainer.classList.add('hidden');

    // Spools spinning
    DOM.leftSpool.classList.add('spinning');
    DOM.rightSpool.classList.add('spinning');

    // Timer loop
    DOM.recordingTimer.textContent = "00:00";
    STATE.recordTimerInterval = setInterval(() => {
      STATE.recordDuration++;
      DOM.recordingTimer.textContent = formatTimerSeconds(STATE.recordDuration);
      
      // Animate tape roll getting slightly thicker on right spool/smaller on left
      const rollSize = 35 - (STATE.recordDuration * 0.1);
      DOM.tapeRoll.style.width = `${Math.max(10, rollSize)}px`;
    }, 1000);

    // Audio Graph Analyzer setup
    STATE.audioContext = new (window.AudioContext || window.webkitAudioContext)();
    STATE.analyser = STATE.audioContext.createAnalyser();
    const source = STATE.audioContext.createMediaStreamSource(STATE.audioStream);
    source.connect(STATE.analyser);
    
    STATE.analyser.fftSize = 64;
    const bufferLength = STATE.analyser.frequencyBinCount;
    const dataArray = new Uint8Array(bufferLength);

    // Visualizer draw loop
    const canvas = DOM.audioVisualizer;
    const ctx = canvas.getContext('2d');
    canvas.width = canvas.parentElement.clientWidth;
    canvas.height = canvas.parentElement.clientHeight;

    function drawWave() {
      if (!STATE.isRecording) return;
      STATE.visualizerAnimFrame = requestAnimationFrame(drawWave);
      
      STATE.analyser.getByteFrequencyData(dataArray);
      
      ctx.fillStyle = '#ffffff';
      ctx.fillRect(0, 0, canvas.width, canvas.height);
      
      const barWidth = (canvas.width / bufferLength) * 1.5;
      let barHeight;
      let x = 0;
      
      for (let i = 0; i < bufferLength; i++) {
        barHeight = dataArray[i] / 2.2;
        
        // Draw double sided bar mirroring center line (brutalist design)
        ctx.fillStyle = '#0000ff';
        ctx.strokeStyle = '#000000';
        ctx.lineWidth = 1;
        
        const yTop = (canvas.height / 2) - barHeight;
        const hVal = barHeight * 2;
        
        ctx.fillRect(x, yTop, barWidth - 2, hVal);
        ctx.strokeRect(x, yTop, barWidth - 2, hVal);
        
        x += barWidth;
      }
    }
    
    // Start MediaRecorder
    STATE.mediaRecorder = new MediaRecorder(STATE.audioStream);
    STATE.mediaRecorder.ondataavailable = (event) => {
      if (event.data.size > 0) {
        STATE.audioChunks.push(event.data);
      }
    };
    
    STATE.mediaRecorder.onstop = async () => {
      const audioBlob = new Blob(STATE.audioChunks, { type: 'audio/webm' });
      STATE.activeNote.content = audioBlob;
      
      // Reset spools and text
      DOM.leftSpool.classList.remove('spinning');
      DOM.rightSpool.classList.remove('spinning');
      DOM.recordingState.textContent = "RECORDING COMPLETED";
      DOM.cassetteLabelTitle.textContent = STATE.activeNote.title || 'VOICE RECORDING';

      setupCustomPlayer(audioBlob);
      triggerAutoSave();
    };

    STATE.mediaRecorder.start();
    drawWave();

  } catch (err) {
    console.error("Recording initialization failed", err);
    showNotification("ERROR: Mic access denied or not found!", "error");
    setMascot('(ಠ_ಠ)', 'no mic access', 'active');
    stopAudioRecording();
  }
}

function stopAudioRecording() {
  if (!STATE.isRecording) return;
  STATE.isRecording = false;
  
  Synth.play('record-stop');
  setMascot('(•‿•)', 'audio saved', 'active');

  // Stop MediaRecorder
  if (STATE.mediaRecorder && STATE.mediaRecorder.state !== 'inactive') {
    STATE.mediaRecorder.stop();
  }

  // Clear timers/intervals
  clearInterval(STATE.recordTimerInterval);
  cancelAnimationFrame(STATE.visualizerAnimFrame);
  
  // Stop mic stream tracks
  if (STATE.audioStream) {
    STATE.audioStream.getTracks().forEach(track => track.stop());
  }

  // Clean Audio Context
  if (STATE.audioContext) {
    STATE.audioContext.close();
  }

  // Reset visualizer lines
  drawStaticVisualizer();

  // Reset controls
  DOM.recBtn.classList.remove('recording');
  DOM.recBtn.innerHTML = '<span class="rec-icon"></span> REC';
  DOM.stopBtn.classList.add('disabled');
  DOM.stopBtn.disabled = true;
}

// Format seconds to 00:00 style
function formatTimerSeconds(seconds) {
  const m = String(Math.floor(seconds / 60)).padStart(2, '0');
  const s = String(seconds % 60).padStart(2, '0');
  return `${m}:${s}`;
}

// --- CUSTOM AUDIO PLAYER CONTROLLER ---
function setupCustomPlayer(blob) {
  const url = URL.createObjectURL(blob);
  
  if (STATE.playbackAudio) {
    STATE.playbackAudio.src = url;
  } else {
    STATE.playbackAudio = new Audio(url);
  }

  DOM.audioPlayerContainer.classList.remove('hidden');
  DOM.playerPlayBtn.textContent = "▶";
  DOM.playerProgress.value = 0;
  DOM.playerCurrentTime.textContent = "0:00";

  STATE.playbackAudio.onloadedmetadata = () => {
    DOM.playerDuration.textContent = formatPlayerTime(STATE.playbackAudio.duration);
    DOM.playerProgress.max = Math.floor(STATE.playbackAudio.duration) || 100;
  };

  STATE.playbackAudio.onended = () => {
    DOM.playerPlayBtn.textContent = "▶";
    DOM.playerProgress.value = 0;
    DOM.playerCurrentTime.textContent = "0:00";
    DOM.leftSpool.classList.remove('spinning');
    DOM.rightSpool.classList.remove('spinning');
    clearInterval(STATE.playbackInterval);
  };
}

function formatPlayerTime(time) {
  if (isNaN(time)) return "0:00";
  const m = Math.floor(time / 60);
  const s = String(Math.floor(time % 60)).padStart(2, '0');
  return `${m}:${s}`;
}

function toggleAudioPlayback() {
  if (!STATE.playbackAudio) return;

  if (STATE.playbackAudio.paused) {
    STATE.playbackAudio.play();
    DOM.playerPlayBtn.textContent = "⏸";
    DOM.leftSpool.classList.add('spinning');
    DOM.rightSpool.classList.add('spinning');
    setMascot('♩(♪_♪)♩', 'playing audio', 'active');
    Synth.play('click');

    // Progress updates
    STATE.playbackInterval = setInterval(() => {
      DOM.playerProgress.value = Math.floor(STATE.playbackAudio.currentTime);
      DOM.playerCurrentTime.textContent = formatPlayerTime(STATE.playbackAudio.currentTime);
    }, 250);
  } else {
    stopAudioPlayback();
    Synth.play('click');
  }
}

function stopAudioPlayback() {
  if (STATE.playbackAudio && !STATE.playbackAudio.paused) {
    STATE.playbackAudio.pause();
    DOM.playerPlayBtn.textContent = "▶";
    DOM.leftSpool.classList.remove('spinning');
    DOM.rightSpool.classList.remove('spinning');
    setMascot('(•‿•)', 'audio paused', 'active');
    clearInterval(STATE.playbackInterval);
  }
}

// --- SAVE / DELETE EVENT FLOW ---

function triggerAutoSave() {
  DOM.saveStatus.textContent = "CHANGING...";
  DOM.saveStatus.className = "save-status-badge saving";
  
  clearTimeout(STATE.saveDebounceTimeout);
  STATE.saveDebounceTimeout = setTimeout(async () => {
    await saveActiveNoteSilently();
  }, 1000); // Auto save 1s after user pauses input
}

async function saveActiveNoteSilently() {
  // Read current layout variables
  STATE.activeNote.title = DOM.noteTitle.value.trim() || 'Untitled Note';
  STATE.activeNote.paperType = DOM.paperStyleSelect.value;
  STATE.activeNote.fontFamily = DOM.fontSelect.value;

  // Bind to date link states
  if (DOM.linkToDateChk.checked) {
    STATE.activeNote.dateString = DOM.noteDatePicker.value;
    STATE.activeNote.timeString = DOM.noteTimePicker.value || null;
  } else {
    STATE.activeNote.dateString = null;
    STATE.activeNote.timeString = null;
  }

  // Double check content values
  if (STATE.activeNote.type === 'text') {
    STATE.activeNote.content = DOM.noteTextarea.value;
  }
  // (Checklist arrays and Audio Blobs are managed inline upon edits/stop-rec)

  // Save stickers state
  if (window.StickerEngine) {
    STATE.activeNote.stickers = StickerEngine.serialize();
  }

  try {
    await DB.save(STATE.activeNote);
    await reloadDatabaseState();
    
    DOM.saveStatus.textContent = "SAVED";
    DOM.saveStatus.className = "save-status-badge saved";
    DOM.deleteActiveNoteBtn.textContent = "🗑️ DELETE ENTRY";

    // Refresh UI dependencies
    renderCalendar();
    renderArchive();
  } catch (err) {
    console.error("Auto-save failed", err);
    DOM.saveStatus.textContent = "ERROR";
    DOM.saveStatus.className = "save-status-badge";
  }
}

async function forceSaveNoteBtnClick() {
  await saveActiveNoteSilently();
  Synth.play('success');
  showNotification("ENTRY SAVED!");
}

async function deleteActiveNote() {
  if (!STATE.activeNote.id) return;

  const exists = STATE.entries.some(e => e.id === STATE.activeNote.id);
  
  if (!exists) {
    if (!confirm("Discard this unsaved draft? All inputs will be cleared.")) {
      return;
    }
    Synth.play('delete');
    stopAudioPlayback();
    
    const blank = createBlankNote(STATE.activeNote.dateString);
    loadNoteIntoWorkspace(blank);
    showNotification("DRAFT DISCARDED!");
    return;
  }
  
  if (!confirm("Are you sure you want to delete this note permanently?")) {
    return;
  }

  try {
    Synth.play('delete');
    stopAudioPlayback();
    
    await DB.delete(STATE.activeNote.id);
    await reloadDatabaseState();

    showNotification("ENTRY DELETED!");
    setMascot('(>_<)', 'note deleted', 'active');
    
    // Clear editor
    const blank = createBlankNote(STATE.selectedDate);
    loadNoteIntoWorkspace(blank);

    // Refresh calendar/archive UI
    renderCalendar();
    renderArchive();
  } catch (err) {
    console.error("Delete failed", err);
  }
}

// --- ARCHIVE VIEW PANEL ---
function renderArchive() {
  DOM.archiveList.innerHTML = '';

  const searchVal = DOM.archiveSearch.value.toLowerCase().trim();
  const filterType = document.querySelector('.archive-filter-btn.active').dataset.filter;
  const dateFilter = DOM.archiveDateFilter.value;
  const sortBy = DOM.archiveSort.value;

  // Filter entries
  let filtered = STATE.entries.filter(e => {
    // 1. Text Search matching title or contents
    let textMatch = true;
    if (searchVal) {
      const titleMatch = e.title.toLowerCase().includes(searchVal);
      let contentMatch = false;
      if (e.type === 'text') {
        contentMatch = e.content.toLowerCase().includes(searchVal);
      } else if (e.type === 'list' && Array.isArray(e.content)) {
        contentMatch = e.content.some(item => item.text.toLowerCase().includes(searchVal));
      }
      textMatch = titleMatch || contentMatch;
    }

    // 2. Tab Filter type
    let typeMatch = true;
    if (filterType !== 'all') {
      typeMatch = e.type === filterType;
    }

    // 3. Date relation link filter
    let dateLinkMatch = true;
    if (dateFilter === 'calendar') {
      dateLinkMatch = !!e.dateString;
    } else if (dateFilter === 'dateless') {
      dateLinkMatch = !e.dateString;
    }

    return textMatch && typeMatch && dateLinkMatch;
  });

  // Sort entries
  filtered.sort((a, b) => {
    if (sortBy === 'newest') {
      return b.createdAt - a.createdAt;
    } else if (sortBy === 'oldest') {
      return a.createdAt - b.createdAt;
    } else if (sortBy === 'alphabetical') {
      return a.title.localeCompare(b.title);
    }
    return 0;
  });

  if (filtered.length === 0) {
    DOM.archiveList.innerHTML = '<div class="empty-state">No matching entries.</div>';
    return;
  }

  filtered.forEach(e => {
    const card = document.createElement('div');
    card.classList.add('archive-entry');
    
    // Highlight if selected
    if (e.id === STATE.activeNote.id) {
      card.classList.add('selected');
    }

    // Header row (icon + title + delete button)
    const headerRow = document.createElement('div');
    headerRow.classList.add('entry-header-row');

    const titleBox = document.createElement('div');
    titleBox.classList.add('entry-title-box');

    const icon = document.createElement('span');
    icon.classList.add('entry-type-icon');
    if (e.type === 'text') icon.textContent = '📝';
    else if (e.type === 'list') icon.textContent = '☑️';
    else if (e.type === 'audio') icon.textContent = '🎙️';
    titleBox.appendChild(icon);

    const title = document.createElement('span');
    title.classList.add('entry-title');
    title.textContent = e.title || 'Untitled Note';
    titleBox.appendChild(title);
    headerRow.appendChild(titleBox);

    const delBtn = document.createElement('button');
    delBtn.classList.add('delete-entry-btn');
    delBtn.innerHTML = '×';
    delBtn.title = "Delete entry";
    headerRow.appendChild(delBtn);

    card.appendChild(headerRow);

    // Snippet preview content
    const snippet = document.createElement('p');
    snippet.classList.add('entry-snippet');
    if (e.type === 'text') {
      snippet.textContent = e.content || 'Empty note';
    } else if (e.type === 'list') {
      const total = e.content.length;
      const checked = e.content.filter(i => i.checked).length;
      snippet.textContent = `${checked} of ${total} tasks checked off`;
    } else if (e.type === 'audio') {
      snippet.textContent = `Voice recording memo — Playable in workspace`;
    }
    card.appendChild(snippet);

    // Metadata badges row
    const badgesRow = document.createElement('div');
    badgesRow.classList.add('entry-meta-tags');

    if (e.dateString) {
      const dbadge = document.createElement('span');
      dbadge.classList.add('entry-tag', 'tag-date');
      dbadge.textContent = `📅 ${e.dateString}`;
      badgesRow.appendChild(dbadge);

      if (e.timeString) {
        const tbadge = document.createElement('span');
        tbadge.classList.add('entry-tag', 'tag-time');
        tbadge.textContent = `⏰ ${e.timeString}`;
        badgesRow.appendChild(tbadge);
      }
    }

    const pbadge = document.createElement('span');
    pbadge.classList.add('entry-tag', 'tag-paper');
    pbadge.textContent = `${e.paperType.toUpperCase()}`;
    badgesRow.appendChild(pbadge);

    card.appendChild(badgesRow);

    // Event listeners
    card.addEventListener('click', (ev) => {
      // Don't trigger if they clicked the entry card's delete cross
      if (ev.target === delBtn) return;
      Synth.play('click');
      loadNoteIntoWorkspace(e);
      
      // Update highlights
      document.querySelectorAll('.archive-entry').forEach(c => c.classList.remove('selected'));
      card.classList.add('selected');
      
      // Update calendar highlight if note is linked to a date
      if (e.dateString) {
        STATE.selectedDate = e.dateString;
        currentCalendarYear = parseInt(e.dateString.split('-')[0]);
        currentCalendarMonth = parseInt(e.dateString.split('-')[1]) - 1;
        DOM.calendarMonthSelect.value = currentCalendarMonth;
        DOM.calendarYearSelect.value = currentCalendarYear;
        renderCalendar();
        updateSelectedDateInfoDisplay();
      }
    });

    delBtn.addEventListener('click', async (ev) => {
      ev.stopPropagation();
      if (!confirm(`Delete "${e.title || 'Untitled'}" permanently?`)) return;
      
      try {
        Synth.play('delete');
        if (STATE.activeNote.id === e.id) {
          stopAudioPlayback();
          const blank = createBlankNote(STATE.selectedDate);
          loadNoteIntoWorkspace(blank);
        }
        await DB.delete(e.id);
        await reloadDatabaseState();
        showNotification("ENTRY DELETED!");
        renderCalendar();
        renderArchive();
      } catch (err) {
        console.error(err);
      }
    });

    DOM.archiveList.appendChild(card);
  });
}

// --- DESKTOP WINDOW MANAGEMENT ---
function toggleDesktopWindow(name, forceState = null, silent = false) {
  if (!silent) Synth.play('click');
  
  let targetWindow, targetBtn;
  if (name === 'calendar') {
    targetWindow = DOM.windowCalendar;
    targetBtn = DOM.toggleCalendarBtn;
  } else if (name === 'editor') {
    targetWindow = DOM.windowEditor;
    targetBtn = DOM.toggleEditorBtn;
  } else if (name === 'archive') {
    targetWindow = DOM.windowArchive;
    targetBtn = DOM.toggleArchiveBtn;
  }

  if (!targetWindow || !targetBtn) return;

  const isClosed = targetWindow.classList.contains('closed');
  const shouldClose = forceState !== null ? !forceState : !isClosed;

  if (shouldClose) {
    targetWindow.classList.add('closed');
    targetBtn.classList.remove('active');
    localStorage.setItem(`win_${name}_visible`, 'false');
    if (!silent) setMascot('(◕‿◕)', `closed ${name}`, 'active');
  } else {
    targetWindow.classList.remove('closed');
    targetBtn.classList.add('active');
    localStorage.setItem(`win_${name}_visible`, 'true');
    if (!silent) setMascot('(•‿•)', `opened ${name}`, 'active');
  }
}

function loadWindowLayoutSettings() {
  ['calendar', 'editor', 'archive'].forEach(name => {
    const visible = localStorage.getItem(`win_${name}_visible`);
    if (visible === 'false') {
      toggleDesktopWindow(name, false, true); // force close silently
    }
  });
}

